{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --exclude '**/node_modules/**' --env-file-if-exists=.env src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "tsx src/index.ts",
    "verify:schema": "tsx --env-file-if-exists=.env scripts/verify-schema.ts",
    "test:mentor": "tsx scripts/test-mentor-heuristics.ts",
    "ingest:syllabus": "tsx --env-file-if-exists=.env src/ingest/syllabus.ts",
    "ingest:pyq": "tsx --env-file-if-exists=.env src/ingest/pyq.ts",
    "ingest:pyq:load": "tsx --env-file-if-exists=.env src/ingest/pyq-load.ts",
    "ingest:resolve": "tsx --env-file-if-exists=.env src/ingest/resolve.ts",
    "ingest:explain": "tsx --env-file-if-exists=.env src/ingest/explain.ts",
    "ingest:assemble": "tsx --env-file-if-exists=.env src/ingest/agent-assemble.ts",
    "ingest:align-key": "tsx --env-file-if-exists=.env src/ingest/align-key.ts",
    "ingest:tests": "tsx --env-file-if-exists=.env src/ingest/tests.ts",
    "ingest:embed": "tsx --env-file-if-exists=.env src/ingest/embed.ts",
    "ingest:verify": "tsx --env-file-if-exists=.env src/ingest/verify.ts",
    "eval:answers": "tsx --env-file-if-exists=.env scripts/eval-harness.ts",
    "cost:report": "tsx --env-file-if-exists=.env scripts/cost-report.ts",
    "audit:consistency": "tsx --env-file-if-exists=.env src/audit/consistency-run.ts",
    "audit:resolve": "tsx --env-file-if-exists=.env src/audit/resolve-run.ts",
    "ca:run": "tsx --env-file-if-exists=.env src/ca/run.ts",
    "ca:compile": "tsx --env-file-if-exists=.env src/ca/compile.ts",
    "daily:build": "tsx --env-file-if-exists=.env src/daily/run.ts",
    "mocks:build": "tsx --env-file-if-exists=.env src/mocks/build.ts",
    "mocks:build:mains": "tsx --env-file-if-exists=.env src/mocks/build-mains.ts",
    "mastery:build": "tsx --env-file-if-exists=.env src/mastery/cli.ts",
    "qgen": "tsx --env-file-if-exists=.env src/qgen/cli.ts",
    "qgen:topup": "tsx --env-file-if-exists=.env src/qgen/cli.ts --topup",
    "notes:gen": "tsx --env-file-if-exists=.env src/notes/cli.ts",
    "notes:embed": "tsx --env-file-if-exists=.env src/notes/embed.ts",
    "migrate:dev-user": "tsx --env-file-if-exists=.env scripts/migrate-dev-user.ts",
    "security:rls": "tsx --env-file-if-exists=.env --env-file=../web/.env.local scripts/rls-security-check.ts",
    "set-password": "tsx --env-file-if-exists=.env scripts/set-password.ts",
    "push:send": "tsx --env-file-if-exists=.env scripts/send-push.ts",
    "nightly:settle": "tsx --env-file-if-exists=.env scripts/nightly-settle.ts",
    "notifications:run": "tsx --env-file-if-exists=.env scripts/notifications-run.ts",
    "demo:seed": "tsx --env-file-if-exists=.env scripts/seed-demo-account.ts",
    "og:generate": "tsx scripts/generate-marketing-og.ts",
    "ca:assemble": "tsx --env-file-if-exists=.env src/ca/assemble-run.ts",
    "ca:backfill": "tsx --env-file-if-exists=.env src/ca/backfill-run.ts",
    "ca:deepdive": "tsx --env-file-if-exists=.env src/ca/deepdive-run.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/noto-sans-devanagari": "^5.2.8",
    "@prayasup/shared": "workspace:*",
    "@resvg/resvg-js": "^2.6.2",
    "@sentry/node": "^10.64.0",
    "@supabase/supabase-js": "^2.110.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "helmet": "^7.1.0",
    "jose": "^6.2.3",
    "node-cron": "^4.6.0",
    "openai": "^6.45.0",
    "pdf-lib": "^1.17.1",
    "pino": "^9.4.0",
    "pino-http": "^10.3.0",
    "rss-parser": "^3.13.0",
    "satori": "^0.26.0",
    "ts-fsrs": "5.4.1",
    "tsx": "^4.19.1",
    "web-push": "^3.6.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.19.0",
    "@types/node-cron": "^3.0.11",
    "@types/web-push": "^3.6.4",
    "pino-pretty": "^11.2.2",
    "typescript": "^5.6.3"
  }
}
