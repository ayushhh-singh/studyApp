# Server
PORT=4000
NODE_ENV=development

# CORS allowlist for the deployed web origin(s), comma-separated (localhost:3000
# is always allowed for dev and never needs to be listed here). e.g.
# ALLOWED_ORIGINS=https://prayasup.app,https://www.prayasup.app
ALLOWED_ORIGINS=

# Supabase (cloud project — create at supabase.com, same project used for local + prod)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Only used by `supabase db push` to apply migrations non-interactively
# (see supabase/README.md). Not needed by the app or ingest runtime.
SUPABASE_DB_PASSWORD=

# LLM — Anthropic for evaluation/structuring/vision; OpenAI for embeddings
# (text-embedding-3-small, 1536-dim — see src/lib/embeddings.ts).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Auth: the API verifies each request's Supabase JWT against the project's JWKS
# endpoint, derived from SUPABASE_URL above — no extra config needed. (The
# DEV_USER_ID stand-in was removed when real Supabase Auth landed.)

# Review Queue access is gated by the users_profile.is_admin flag (migration
# 0054), not an env var — no ADMIN_MODE setting anymore. Seed an admin via SQL
# (update users_profile set is_admin=true where id=<auth uid>).

# Nightly qgen top-up cost ceiling (USD) for `pnpm qgen:topup` (Message Batches,
# 0.5x). The job trims shortfall nodes to fit and defers the rest. Default 5.
QGEN_BATCH_MAX_USD=5

# Billing — Razorpay (test mode). Create test keys at dashboard.razorpay.com
# (Settings → API Keys). The webhook secret is set when you add a webhook
# endpoint (Settings → Webhooks) pointing at POST /api/v1/billing/webhook; it
# must match RAZORPAY_WEBHOOK_SECRET here. KEY_ID is browser-safe (returned to
# checkout.js by /billing/order); the SECRET and WEBHOOK_SECRET are server-only.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Web push (VAPID). Generate a pair with `npx web-push generate-vapid-keys`.
# PUBLIC_KEY must exactly match apps/web/.env.local's VITE_VAPID_PUBLIC_KEY —
# the browser signs its subscription against the public key, and the server
# signs the push payload with the private key; a mismatch fails silently as a
# 401 from the push service, not a helpful error.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Optional: Sentry error tracking (server). No DSN = Sentry is a no-op.
SENTRY_DSN=
