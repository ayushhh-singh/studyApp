# Server
PORT=4000

# Supabase (cloud project — create at supabase.com, same project used for local + prod)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Only used by `supabase db push` to apply migrations non-interactively
# (see supabase/README.md). Not needed by the app or ingest runtime.
SUPABASE_DB_PASSWORD=

# LLM — Anthropic for evaluation/structuring/vision; OpenAI for embeddings
# (text-embedding-3-small, 1536-dim — see src/lib/embeddings.ts).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Dev-only auth stand-in (removed in Session 15)
DEV_USER_ID=
