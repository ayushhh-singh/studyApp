VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_API_URL=http://localhost:4000

# Build-time only, not read at runtime (see vite.config.ts / router.tsx).
# Unset (or anything but "sukoon") builds Neev as normal. VITE_APP=sukoon
# builds the standalone Sukoon deployable: mounts Sukoon at "/" with its own
# PWA manifest/branding and no Neev routes in the bundle at all — set it in
# the shell before the command (VITE_APP=sukoon pnpm --filter web build), or
# use the pnpm --filter web build:sukoon / dev:sukoon scripts.
VITE_APP=

# Web push (VAPID public half only — browser-safe). Must match apps/api/.env's
# VAPID_PUBLIC_KEY exactly.
VITE_VAPID_PUBLIC_KEY=

# Optional: Sentry error tracking (browser). No DSN = Sentry is a no-op.
VITE_SENTRY_DSN=
