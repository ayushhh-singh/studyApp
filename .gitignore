# Content pipeline: ignore downloaded binaries, but COMMIT the yaml + manifest.
# A fresh clone repopulates the binaries with `pnpm content:fetch`.
content-raw/**/*.pdf
content-raw/**/*.PDF
content-raw/**/*.zip
content-raw/**/*.doc
content-raw/**/*.docx
!content-raw/manifest.json
