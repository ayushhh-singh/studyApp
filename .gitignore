node_modules/
.env
.env.local
.env.*.local
.next/
dist/
build/
*.log
.DS_Store
.turbo/
coverage/

# Content pipeline: ignore downloaded binaries, but COMMIT the yaml + manifest.
# A fresh clone repopulates the binaries with `pnpm content:fetch`.
content-raw/**/*.pdf
content-raw/**/*.PDF
content-raw/**/*.zip
content-raw/**/*.doc
content-raw/**/*.docx
content-raw/**/*.jpg
content-raw/**/*.jpeg
content-raw/**/*.png
content-raw/**/*.webp
!content-raw/manifest.json

# ingest:pyq / ingest:syllabus --dry-run write review artifacts here. They are
# regenerated from the source PDFs on demand; the reviewed content lands in
# Supabase via ingest:*:load, so the JSON itself is not committed.
content-raw/parsed/

# Session 27.5: quarantined non-UPPSC contamination + redundant scans (disk-only)
content-raw/_excluded_non_uppsc/
content-raw/_redundant_scans/
.env.prod
.env.*.prod
!.env.example
